:{$PORT:8080} {
    log {
        output stdout
    }

    # Compress everything
    encode gzip zstd

    route {
        # Health check
        handle /ping {
            respond "OK" 200
        }

        # Static Asset Caching (Images, Fonts, PDF, Video)
        @static {
            path *.jpg *.jpeg *.png *.svg *.webp *.avif *.ico *.woff *.woff2 *.pdf *.mp4
        }
        header @static Cache-Control "public, max-age=31536000, immutable"

        # Versioned/Frequent Assets (CSS, JS)
        @assets {
            path *.css *.js
        }
        header @assets Cache-Control "public, max-age=3600, must-revalidate"

        # Main site
        handle {
            root * /srv/mjw
            
            # Security Headers
            header {
                X-Frame-Options "SAMEORIGIN"
                X-Content-Type-Options "nosniff"
                Referrer-Policy "strict-origin-when-cross-origin"
                Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
                Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
                # Updated CSP for Cloudflare Analytics, Medium content, and Phaser Game
                Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://ajax.googleapis.com https://d3e54v103j8qbb.cloudfront.net https://api.rss2json.com https://*.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://*.medium.com https://medium.com; connect-src 'self' https://api.rss2json.com https://*.cloudflareinsights.com; frame-src 'none'; object-src 'none'; worker-src 'self' blob:;"
            }
            
            try_files {path} {path}.html {path}/ =404
            file_server
        }
    }
}
